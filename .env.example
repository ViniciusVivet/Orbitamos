# Orbitamos root env example
#
# A producao atual usa apps/web na Vercel com Supabase.
# Este arquivo existe apenas para desenvolvimento local/legado do backend Spring em apps/api.
# Nao copie credenciais reais de Supabase, Cloudinary, Vercel ou contas pessoais para ca.

# Legacy Spring API local database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orbitamos
SPRING_DATASOURCE_USERNAME=orbitamos
SPRING_DATASOURCE_PASSWORD=senha_local_de_desenvolvimento

# Legacy JWT local secret
JWT_SECRET=<defina_um_secret_local_de_32_chars>
JWT_EXPIRATION=86400000

# Optional legacy CORS override
# SPRING_WEB_CORS_ALLOWED_ORIGINS=https://orbitamosbr.com,https://www.orbitamosbr.com

# Optional legacy public API base URL
# API_BASE_URL=http://localhost:8080

# Optional legacy Cloudinary config
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
