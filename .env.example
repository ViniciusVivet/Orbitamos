# ============================================
# Backend Environment Variables - Orbitamos
# ============================================
# Copie este arquivo para .env (na raiz do projeto) - USE SГ“ EM DESENVOLVIMENTO LOCAL.
# IMPORTANTE: NUNCA commite o arquivo .env (jГЎ estГЎ no .gitignore).
# Onde configurar em produГ§ГЈo:
#   RENDER: Dashboard в†’ orbitamos-backend в†’ Environment (veja docs/RENDER_SUPABASE_SETUP.md).
#   EC2:    scripts/ec2-env.sh (nГЈo commitar); source antes do java -jar (veja docs/EC2_CLOUDFRONT_HTTPS.md).
# Comparativo Render vs EC2: docs/VARIAVEIS_AMBIENTE.md
# Nunca coloque credenciais reais do Supabase aqui; valores abaixo sГЈo sГі para banco local.

# ============================================
# Banco de Dados (Supabase/PostgreSQL)
# ============================================
# OPГ‡ГѓO A - Supabase (use quando for usar banco na nuvem / Render):
#   Pegue em: Supabase Dashboard в†’ Settings в†’ Database в†’ Connection string (URI)
#   Formato JDBC: jdbc:postgresql://db.XXXXX.supabase.co:5432/postgres
#   Supabase exige SSL: adicione ?sslmode=require
#   Exemplo: jdbc:postgresql://db.abcdefgh.supabase.co:5432/postgres?sslmode=require
#   (O cГіdigo adiciona timeouts na URL automaticamente no deploy вЂ” nГЈo precisa mudar nada no Render.)
# OPГ‡ГѓO B - Banco local (Docker/postgres na sua mГЎquina):
#   Com Docker Compose SEM serviГ§o postgres: use localhost sГі se o postgres rodar na sua mГЎquina.
#   Com postgres em outro container: use o nome do serviГ§o, ex. jdbc:postgresql://db:5432/orbitamos
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orbitamos
SPRING_DATASOURCE_USERNAME=orbitamos
SPRING_DATASOURCE_PASSWORD=orbitamos123

# ============================================
# JWT (AutenticaГ§ГЈo) - OBRIGATГ“RIO em produГ§ГЈo
# ============================================
# Gere uma chave forte de pelo menos 32 caracteres
# Exemplo de geraГѓВ§ГѓВЈo: openssl rand -base64 32
# NГЈo deixe vazio em produГ§ГЈo - configure no Render. Em dev pode ficar vazio (API usa valor default).
JWT_SECRET=

# ExpiraГѓВ§ГѓВЈo do token em milissegundos (padrГѓВЈo: 24 horas = 86400000)
JWT_EXPIRATION=86400000

# ============================================
# CORS (Origins permitidos - opcional)
# ============================================
# URLs separadas por viВ­rgula (opcional, jГЎ configurado no application.yml)
# Dominio oficial ja liberado no codigo:
#   https://orbitamosbr.com,https://www.orbitamosbr.com
# Use esta variavel apenas para liberar dominios extras sem redeploy de codigo.
# SPRING_WEB_CORS_ALLOWED_ORIGINS=https://meu-site.com,https://outro-site.com

# ============================================
# URL base da API (legado - links de imagem antigos)
# ============================================
# No EC2 + CloudFront: defina API_BASE_URL=https://SEU_ID.cloudfront.net
# Em producao HTTPS, defina tambem APP_COOKIE_SECURE=true.
# Em local: nГЈo precisa (usa http://localhost:8080).
# Obs: o upload de avatar agora vai direto para o Cloudinary; esta var sГі
# afeta URLs de uploads antigos armazenados no sistema de arquivos.
# API_BASE_URL=

# ============================================
# Cloudinary (storage permanente de avatars)
# ============================================
# Credenciais em: cloudinary.com в†’ Dashboard
# Em produГ§ГЈo (EC2): adicionar no ec2-env.sh
CLOUDINARY_CLOUD_NAME=dt6srlfcj
CLOUDINARY_API_KEY=828728432781183
CLOUDINARY_API_SECRET=
