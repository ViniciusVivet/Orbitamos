# Copie este arquivo para .env e preencha valores locais.
# Nunca use credenciais reais de producao em arquivos versionados.

# Banco de dados local ou ambiente de desenvolvimento
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orbitamos
SPRING_DATASOURCE_USERNAME=orbitamos
SPRING_DATASOURCE_PASSWORD=senha_local_de_desenvolvimento

# JWT legado local
JWT_SECRET=<defina_um_secret_local_de_32_chars>

# Cloudinary opcional para desenvolvimento local
CLOUDINARY_CLOUD_NAME=<seu_cloud_name>
CLOUDINARY_API_KEY=<sua_api_key>
CLOUDINARY_API_SECRET=<sua_api_secret>
