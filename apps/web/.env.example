# Orbitamos web env example
# Copy to apps/web/.env.local for local development.

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY

# Legacy Spring API fallback. Leave empty/absent while Supabase is the active backend.
# NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Optional EmailJS notification through apps/web/src/app/api/contact/route.ts
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
