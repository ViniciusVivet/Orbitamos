# ============================================
# Frontend Environment Variables - Orbitamos
# ============================================
# Copie este arquivo para .env.local (não será commitado)
# IMPORTANTE: NUNCA commite o arquivo .env.local (ele está no .gitignore)
#
# Infra atual: ver docs/INFRA_ATUAL.md

# ============================================
# URL da API do Backend
# ============================================
# Local (desenvolvimento):
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Produção (Vercel) — use a URL HTTPS do CloudFront:
# NEXT_PUBLIC_API_URL=https://SEU_ID.cloudfront.net/api
#
# Para saber qual é a URL: docs/INFRA_ATUAL.md ou console AWS → CloudFront → Domain name

# ============================================
# EmailJS (Notificações por Email)
# ============================================
# Opcional - Configure no dashboard do EmailJS: https://www.emailjs.com/
# OBRIGATÓRIO se quiser que o formulário de contato envie emails
# Para produção: configure essas variáveis no Vercel
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# ============================================
# Notas Importantes
# ============================================
# - Variáveis que começam com NEXT_PUBLIC_ são expostas no navegador
# - Não coloque senhas ou secrets em variáveis NEXT_PUBLIC_*
# - Para produção no Vercel, configure essas variáveis no dashboard
# - Para desenvolvimento local, use este arquivo copiado para .env.local
#
# REMOVIDO: NEXT_PUBLIC_SUPABASE_URL e NEXT_PUBLIC_SUPABASE_ANON_KEY
# O upload de avatar era feito pelo frontend via Supabase Storage.
# Hoje o upload é feito pelo backend (Java) diretamente no Cloudinary.
# Não é mais necessário configurar Supabase Storage no frontend.
